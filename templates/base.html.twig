<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width; initial-scale=1">
        <title>{% block title %}{% endblock %} - Green Goodies</title>
        <link rel="icon" href="{{ asset('img/favicon.png') }}" type="image/png">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body>
        <header class="header">
            <div class="header__container">
                <a href="{{ path('app_home') }}" aria-label="Accueil">
                    <img src="{{ asset('img/green-goodies-logo.svg') }}" alt="Logo Green Goodies" class="header__img">
                </a>
                <nav>
                    <ul class="header__list">
                        <li><a href="#" class="header__link">Nos produits</a></li>
                        <li><a href="#" class="header__link">Mon panier</a></li>
                        <li><a href="#" class="header__link">Mon compte</a></li>
                        <li><a href="#" class="header__link">Déconnexion</a></li>
                    </ul>
                </nav>
            </div>
        </header>
        <main>
            {% block main %}{% endblock %}
        </main>
        <footer class="footer">
            <div class="footer__container">
                <p>© Green Goodies - {{ 'now'|date('Y') }}</p>
            </div>
        </footer>
    </body>
</html>