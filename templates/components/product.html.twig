<article class="product">
    <figure class="product__figure">
        <img src="{{ product.picturePath }}" alt="" class="product__img">
    </figure>
    <div class="product__info">
        <header>
            <h3 class="product__title">{{ product.name }}</h3>
            <p class="product__description">{{ product.shortDescription }}</p>
        </header>
        <span class="product__price">{{ product.price|number_format(2, ',') }}€</span>
        <a href="{{ path('app_product', {id: product.id}) }}" class="product__link">Voir le produit</a>
    </div>
</article>
